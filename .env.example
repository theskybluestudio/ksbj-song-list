# Preferred: publish the Google Sheet as CSV and paste the export URL here.
KSBJ_SONGS_CSV_URL=

# Or set these instead and the app will build the export URL:
# KSBJ_SONGS_SHEET_ID=your_google_sheet_id
# KSBJ_SONGS_GID=0

# Site URL for canonical tags, robots.txt, sitemap.xml, and social metadata:
NEXT_PUBLIC_SITE_URL=https://ksbj.skybluestudio.net

# Optional behavior:
# the app will read application/data/songs.json first when present
# generate that file with: npm run sync
