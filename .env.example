# Optional: publish the Google Sheet as CSV and paste the export URL here.
# If set, the app will use this directly instead of building a sheet export URL.
KSBJ_SONGS_CSV_URL=
KLOVE_SONGS_CSV_URL=

# Shared sheet sync settings used by both the app and collectors:
# KSBJ_SHEET_ID=your_google_sheet_id
# KSBJ_SHEET_TAB=KSBJ Master
# KSBJ_PLAY_LOG_SHEET_TAB=KSBJ Play Log
# KLOVE_SHEET_ID=your_google_sheet_id
# KLOVE_SHEET_TAB=KLOVE Master
# KLOVE_PLAY_LOG_SHEET_TAB=KLOVE Play Log

# Optional sync behavior:
# set to false on standalone VM/app-only deployments to skip writes to ../sources/<station>/data/app-songs.json
# SYNC_SOURCE_CACHE=true

# Site URL for canonical tags, robots.txt, sitemap.xml, and social metadata:
NEXT_PUBLIC_SITE_URL=https://music.skybluestudio.net

# Optional behavior:
# the app will read application/data/ksbj-songs.json first when present
# generate that file with: npm run sync
